#Singly Linked List: Adding an element in the MIDDLE

Explanation:
1. Create the linked list by inserting nodes at the end until -1 is entered.
2. Take input for the new value and the target value (ch) after which insertion is required.
3. Traverse the list to find the node with data ch and insert the new node by adjusting pointers.
4. Display the updated list by traversing from start to NULL.

#include<stdio.h>
#include<stdlib.h>

struct node
{
    int data;
    struct node *next;
};

int main()
{
    struct node *start = NULL, *newnode, *temp;
    int val, ch;

    // Step 1: Create Linked List
    printf("Enter values to create list (-1 to stop): ");
    scanf("%d", &val);

    while(val != -1)
    {
        newnode = (struct node *)malloc(sizeof(struct node));
        newnode->data = val;
        newnode->next = NULL;

        if(start == NULL)
        {
            start = newnode;
        }
        else
        {
            temp = start;
            while(temp->next != NULL)
            {
                temp = temp->next;
            }
            temp->next = newnode;
        }
        scanf("%d", &val);
    }

    // Insert in middle (after given value)
    printf("\nEnter value to insert: ");
    scanf("%d", &val);
    printf("Enter value after which to insert: ");
    scanf("%d", &ch);
    newnode = (struct node *)malloc(sizeof(struct node));
    newnode->data = val;
    temp = start;
    while(temp != NULL && temp->data != ch)
    {
        temp = temp->next;
    }

    if(temp == NULL)
    {
        printf("Value not found\n");
    }
    else
    {
        newnode->next = temp->next;
        temp->next = newnode;
    }

    // Printing Linked List
    printf("\nUpdated Linked List:\n");
    temp = start;
    while(temp != NULL)
    {
        printf("%d \t", temp->data);
        temp = temp->next;
    }

    return 0;
}

