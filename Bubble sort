# Bubble sort

Explanation:
1. Sorting the array into either ascending or descending order
2. Here, a temp variable is used to swap the array positions
3. For increasing order, change to ">" in the swapping variable section
4. For descending order, change to "<" in the swapping variable section

#include <stdio.h>

int main()
{
// Normal array creation //
  int array[100], n, i, j, temp;
  printf("Enter number of elements\n");
  scanf("%d", &n);
  printf("Enter %d integers\n", n);

  for (i=0;i<n;i++)
  {
    scanf("%d", &array[i]);
  }

// Sorting & swapping section //
  for (i=0;i<n-1;i++)
  {
    for (j=0;j<n-i-1;j++)
    {
      if (array[j] > array[j+1]) /* For decreasing order use < */
      {
        temp       = array[j];
        array[j]   = array[j+1];
        array[j+1] = temp;
      }
    }
  }

// Printing final array //
  printf("Sorted list in ascending order:\n");
  for (i=0;i< n;i++)
     printf("%d\n", array[i]);

  return 0;
}

