#Doubly Linked List: Adding an element at the end

Explanation:
1. A new node is dynamically created, and its next pointer is set to NULL.
2. If the list is empty, the new node becomes the start node.
3. Otherwise, traversal is done until the last node using a temporary pointer.
4. The last node’s next is linked to the new node, and the new node’s prev is set to the last node.

#include <stdio.h>
#include <stdlib.h>

struct node
{
    int data;
    struct node *next;
    struct node *prev;
};

int main()
{
    struct node *start = NULL, *newnode, *temp;
    int val;

    printf("Enter value (-1 to stop): ");
    scanf("%d", &val);

    while(val != -1)
    {
        newnode = (struct node*)malloc(sizeof(struct node));
        newnode->data = val;
        newnode->next = NULL;

        if(start == NULL)
        {
            newnode->prev = NULL;
            start = newnode;
        }
        else
        {
            temp = start;
            while(temp->next != NULL)
                temp = temp->next;

            temp->next = newnode;
            newnode->prev = temp;
        }

        printf("Enter value (-1 to stop): ");
        scanf("%d", &val);
    }

    printf("\nDoubly Linked List:\n");
    temp = start;
    while(temp != NULL)
    {
        printf("%d \t", temp->data);
        temp = temp->next;
    }

    return 0;
}

