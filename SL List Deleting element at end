#Singly Linked List: Deleting at the end

Explanation: 
Traverse to last node
Move through the list using temp until temp->next == NULL (this is the last node), while keeping track of the previous node (prev).
Handle single node case
If start->next == NULL, it means only one node exists → free it and set start = NULL.
Update link of previous node
Set prev->next = NULL to remove the last node from the list.
Free the last node
Use free(temp); to delete the node from memory and prevent memory leaks.

#include<stdio.h>
#include<stdlib.h>

struct node
{
    int data;
    struct node *next;
};

int main()
{
    struct node *start = NULL, *newnode, *temp, *prev;
    int val;

    // Step 1: Create Linked List
    printf("Enter values to create list (-1 to stop): ");
    scanf("%d", &val);

    while(val != -1)
    {
        newnode = (struct node *)malloc(sizeof(struct node));
        newnode->data = val;
        newnode->next = NULL;

        if(start == NULL)
        {
            start = newnode;
        }
        else
        {
            temp = start;
            while(temp->next != NULL)
            {
                temp = temp->next;
            }
            temp->next = newnode;
        }

        scanf("%d", &val);
    }

    // Step 2: Delete at End
    if(start == NULL)
    {
        printf("\nList is empty.\n");
    }
    else if(start->next == NULL)
    {
        // Only one node
        free(start);
        start = NULL;
        printf("\nLast node deleted (list is now empty).\n");
    }
    else
    {
        temp = start;
        prev = NULL;

        // Traverse to last node
        while(temp->next != NULL)
        {
            prev = temp;
            temp = temp->next;
        }

        prev->next = NULL;
        free(temp);
        printf("\nLast node deleted successfully.\n");
    }

    // Step 3: Print Linked List
    printf("\nUpdated Linked List:\n");
    temp = start;
    while(temp != NULL)
    {
        printf("%d -> ", temp->data);
        temp = temp->next;
    }
    printf("NULL");

    return 0;
}

