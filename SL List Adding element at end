#Singly Linked List: Adding an element at the end

Explanation:
1. Create the linked list by inserting nodes until -1 is entered.
2. Take input for the new value to be inserted at the end.
3. Traverse to the last node and link the new node using temp->next = newnode.
4. Print the updated linked list from start to NULL.

#include<stdio.h>
#include<stdlib.h>

struct node
{
    int data;
    struct node *next;
};

int main()
{
    struct node *start = NULL, *newnode, *temp;
    int val;

    // Creating Linked List
    printf("Enter values to create list (-1 to stop): ");
    scanf("%d", &val);
    while(val != -1)
    {
        newnode = (struct node *)malloc(sizeof(struct node));
        newnode->data = val;
        newnode->next = NULL;

        if(start == NULL)
        {
            start = newnode;
        }
        else
        {
            temp = start;
            while(temp->next != NULL)
            {
                temp = temp->next;
            }
            temp->next = newnode;
        }

        scanf("%d", &val);
    }

    // Inserting at End
    printf("\nEnter value to insert at end: ");
    scanf("%d", &val);
    newnode = (struct node *)malloc(sizeof(struct node));
    newnode->data = val;
    newnode->next = NULL;

    if(start == NULL)
    {
        start = newnode;
    }
    else
    {
        temp = start;
        while(temp->next != NULL)
        {
            temp = temp->next;
        }
        temp->next = newnode;
    }

    // Printing Linked List
    printf("\nUpdated Linked List:\n");
    temp = start;
    while(temp != NULL)
    {
        printf("%d \t", temp->data);
        temp = temp->next;
    }

    return 0;
}

