#Circular Linked List: Adding an element at the Start

Explanation:
1. Create a new node and store the given value in it.
2. If the list is empty, make start = newnode and newnode->next = start.
3. If not empty, traverse to the last node in the circular list.
4. Update links so the last node points to the new node and the new node becomes the new start.

#include <stdio.h>
#include <stdlib.h>

struct node
{
    int data;
    struct node *next;
};

struct node *start = NULL;

// Function to insert at the beginning
void insert_begin(int val)
{
    struct node *newnode, *temp;

    newnode = (struct node *)malloc(sizeof(struct node));
    newnode->data = val;

    if(start == NULL)
    {
        // If the list is empty
        start = newnode;
        newnode->next = start;
    }
    else
    {
        temp = start;

        // Go to last node
        while(temp->next != start)
        {
            temp = temp->next;
        }

        newnode->next = start;  // New node points to old start
        temp->next = newnode;   // Last node points to new node
        start = newnode;        // Update start
    }
}

// Function to display list
void display()
{
    struct node *temp;

    if(start == NULL)
    {
        printf("List is empty\n");
        return;
    }

    temp = start;
    do
    {
        printf("%d ", temp->data);
        temp = temp->next;
    }
    while(temp != start);
}

int main()
{
    insert_begin(10);
    insert_begin(20);
    insert_begin(30);

    printf("Circular Linked List:\n");
    display();

    return 0;
}

