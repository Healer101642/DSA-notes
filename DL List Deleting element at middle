#Doubly Linked List: Deleting an element in the middle

Explanation:
1. The program creates the list and takes the position to delete from the user.
2. Traversal is done up to the specified position node.
3. The previous node’s next and next node’s prev pointers are adjusted to bypass the node.
4. The selected middle node is removed from memory using free().

#include <stdio.h>
#include <stdlib.h>

struct node
{
    int data;
    struct node *next;
    struct node *prev;
};

int main()
{
    struct node *start = NULL, *newnode, *temp;
    int val, pos, i;

    // Creating list
    printf("Enter value (-1 to stop): ");
    scanf("%d", &val);

    while(val != -1)
    {
        newnode = (struct node*)malloc(sizeof(struct node));
        newnode->data = val;
        newnode->next = NULL;

        if(start == NULL)
        {
            newnode->prev = NULL;
            start = newnode;
        }
        else
        {
            temp = start;
            while(temp->next != NULL)
                temp = temp->next;

            temp->next = newnode;
            newnode->prev = temp;
        }

        printf("Enter value (-1 to stop): ");
        scanf("%d", &val);
    }

    printf("Enter position to delete: ");
    scanf("%d", &pos);

    temp = start;

    for(i = 1; i < pos && temp != NULL; i++)
        temp = temp->next;

    if(temp != NULL)
    {
        if(temp->prev != NULL)
            temp->prev->next = temp->next;
        else
            start = temp->next;

        if(temp->next != NULL)
            temp->next->prev = temp->prev;

        free(temp);
    }

    // Printing list
    printf("\nAfter Deletion:\n");
    temp = start;
    while(temp != NULL)
    {
        printf("%d \t", temp->data);
        temp = temp->next;
    }

    return 0;
}

